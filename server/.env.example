# Порт, на котором запускается backend-сервер
PORT=5000

# Строка подключения к MongoDB Atlas (облачная база данных)
MONGODB_URI=mongodb+srv://<username>:<password>@clusterName.mongodb.net/?appName=appName

# Секретный ключ для JWT-токенов
# Используется для подписи и проверки авторизации пользователей
JWT_SECRET=your_secret_key